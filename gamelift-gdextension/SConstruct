#!/usr/bin/env python
"""
SConstruct file for GameLift GDExtension

This build script compiles the GameLift GDExtension for Godot 4.x
It requires:
- godot-cpp (Godot C++ bindings)
- AWS GameLift Server SDK (built with -DGAMELIFT_USE_STD=1)
- OpenSSL
"""

import os
import sys

# ==============================================================================
# Configuration
# ==============================================================================

# Paths - adjust these to match your environment
GODOT_CPP_PATH = os.environ.get("GODOT_CPP_PATH", "godot-cpp")
GAMELIFT_SDK_PATH = os.environ.get("GAMELIFT_SDK_PATH", "gamelift-server-sdk")
OPENSSL_PATH = os.environ.get("OPENSSL_PATH", "/usr/local/openssl")

# Extension name
EXTENSION_NAME = "gamelift"

# ==============================================================================
# Environment Setup
# ==============================================================================

env = SConscript(os.path.join(GODOT_CPP_PATH, "SConstruct"))

# Add our source path
env.Append(CPPPATH=["src/"])

# ==============================================================================
# Platform-specific Configuration
# ==============================================================================

if env["platform"] == "linux":
    # Linux-specific settings
    env.Append(
        CPPPATH=[
            os.path.join(GAMELIFT_SDK_PATH, "include"),
            os.path.join(OPENSSL_PATH, "include"),
        ]
    )

    env.Append(
        LIBPATH=[
            os.path.join(GAMELIFT_SDK_PATH, "lib"),
            os.path.join(OPENSSL_PATH, "lib"),
        ]
    )

    # Link against GameLift SDK and dependencies
    env.Append(
        LIBS=[
            "aws-cpp-sdk-gamelift-server",
            "ssl",
            "crypto",
            "pthread",
        ]
    )

    # Required for std::string compatibility
    env.Append(CPPDEFINES=["GAMELIFT_USE_STD=1"])

    # C++17 for GameLift SDK
    env.Append(CXXFLAGS=["-std=c++17"])

    # Use old C++ ABI for compatibility
    env.Append(CPPDEFINES=["_GLIBCXX_USE_CXX11_ABI=0"])

elif env["platform"] == "windows":
    # Windows-specific settings
    env.Append(
        CPPPATH=[
            os.path.join(GAMELIFT_SDK_PATH, "include"),
            os.path.join(OPENSSL_PATH, "include"),
        ]
    )

    env.Append(
        LIBPATH=[
            os.path.join(GAMELIFT_SDK_PATH, "lib"),
            os.path.join(OPENSSL_PATH, "lib"),
        ]
    )

    env.Append(
        LIBS=[
            "spdlog",  # Must come BEFORE GameLift SDK (link dependency order)
            "aws-cpp-sdk-gamelift-server",
            "libssl",
            "libcrypto",
            "ws2_32",
            "crypt32",
        ]
    )

    # Required defines
    env.Append(CPPDEFINES=["GAMELIFT_USE_STD=1", "WIN32"])

elif env["platform"] == "macos":
    # macOS-specific settings (for development/testing only - GameLift servers run on Linux/Windows)
    env.Append(
        CPPPATH=[
            os.path.join(GAMELIFT_SDK_PATH, "include"),
            "/usr/local/opt/openssl/include",
        ]
    )

    env.Append(
        LIBPATH=[
            os.path.join(GAMELIFT_SDK_PATH, "lib"),
            "/usr/local/opt/openssl/lib",
        ]
    )

    env.Append(
        LIBS=[
            "aws-cpp-sdk-gamelift-server",
            "ssl",
            "crypto",
        ]
    )

    env.Append(CPPDEFINES=["GAMELIFT_USE_STD=1"])
    env.Append(CXXFLAGS=["-std=c++17"])

# ==============================================================================
# Source Files
# ==============================================================================

sources = Glob("src/*.cpp")

# ==============================================================================
# Build Target
# ==============================================================================

# Determine library suffix based on platform and build type
if env["platform"] == "macos":
    library_suffix = ".{}.{}.framework/{}".format(
        env["platform"], env["target"], EXTENSION_NAME
    )
else:
    library_suffix = ".{}.{}.{}{}".format(
        env["platform"], env["target"], env["arch"], env["SHLIBSUFFIX"]
    )

library_path = "bin/lib{}{}".format(EXTENSION_NAME, library_suffix)

library = env.SharedLibrary(
    library_path,
    source=sources,
)

Default(library)

# ==============================================================================
# Install Target (copy to Godot addons directory)
# ==============================================================================

install_path = os.path.join("..", "addons", "gamelift", "bin")
install_target = env.Install(install_path, library)
env.Alias("install", install_target)

# ==============================================================================
# Help Text
# ==============================================================================

Help(
    """
GameLift GDExtension Build Script
=================================

Usage:
    scons platform=<platform> [target=<target>] [arch=<arch>]

Platforms:
    linux       - Linux (for GameLift deployment)
    windows     - Windows (for GameLift deployment)
    macos       - macOS (for local development only)

Targets:
    template_debug      - Debug build
    template_release    - Release build

Environment Variables:
    GODOT_CPP_PATH      - Path to godot-cpp (default: ./godot-cpp)
    GAMELIFT_SDK_PATH   - Path to GameLift Server SDK (default: ./gamelift-server-sdk)
    OPENSSL_PATH        - Path to OpenSSL installation (default: /usr/local/openssl)

Examples:
    # Build for Linux release (for GameLift deployment)
    scons platform=linux target=template_release

    # Build for Linux debug
    scons platform=linux target=template_debug

    # Build with custom SDK path
    GAMELIFT_SDK_PATH=/path/to/sdk scons platform=linux target=template_release
"""
)
