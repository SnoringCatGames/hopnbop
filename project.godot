; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Jump 'n Thump"
config/version="0.1.0"
run/main_scene="res://src/core/main.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="uid://bsrqq2id8rpl8"

[autoload]

G="*res://src/core/global.gd"
Netcode="*res://addons/rollback_netcode/core/network_orchestrator.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gamelift_session_manager/plugin.cfg", "res://addons/gut/plugin.cfg", "res://addons/rollback_netcode/plugin.cfg")

