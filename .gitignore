# Godot 4+ specific ignores
.godot/
/android/

build/*

# =============================================================================
# GameLift GDExtension Build Artifacts
# =============================================================================

# Intermediate build artifacts (developers rebuild these)
gamelift-gdextension/bin/
gamelift-gdextension/.scons_cache/
gamelift-gdextension/.sconsign.dblite


# Dependencies (developers clone/build these)
gamelift-gdextension/godot-cpp/

# Ignore all of gamelift-server-sdk except custom tracked files
gamelift-gdextension/gamelift-server-sdk/*

# Track custom cmake configuration files (contains MSVC runtime, rapidjson patches)
!gamelift-gdextension/gamelift-server-sdk/cmake/
!gamelift-gdextension/gamelift-server-sdk/cmake/**

# Track root CMakeLists.txt with custom modifications
!gamelift-gdextension/gamelift-server-sdk/CMakeLists.txt

# Track SDK source CMakeLists.txt with MSVC runtime configuration
!gamelift-gdextension/gamelift-server-sdk/gamelift-server-sdk/
!gamelift-gdextension/gamelift-server-sdk/gamelift-server-sdk/CMakeLists.txt

# Track documentation files
!gamelift-gdextension/gamelift-server-sdk/CODE_OF_CONDUCT.md
!gamelift-gdextension/gamelift-server-sdk/CONTRIBUTING.md
!gamelift-gdextension/gamelift-server-sdk/LICENSE
!gamelift-gdextension/gamelift-server-sdk/NOTICE
!gamelift-gdextension/gamelift-server-sdk/README.md

# Build logs
gamelift-gdextension/*.log
gamelift-gdextension/gamelift-server-sdk/*.log
wsl_build.log
build.log

# Object files
*.o
*.os
*.a

# Keep the installed extension in addons/ (needed for game to run)
# This is commented out to show these ARE committed:
# !addons/gamelift/bin/*.so
# !addons/gamelift/gamelift.gdextension

# =============================================================================
# Deployment Artifacts
# =============================================================================

gamelift-deploy/
gamelift-deploy.tar.gz

# =============================================================================
# Test Results
# =============================================================================

test_results.xml
test_results/

# =============================================================================
# IDE & Editor
# =============================================================================

# VSCode local settings (user-specific)
.vscode/settings.local.json

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store

# =============================================================================
# Python
# =============================================================================

__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# =============================================================================
# C++ Build Artifacts
# =============================================================================

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# BUT keep the GameLift extension libraries in addons/
!addons/gamelift/bin/*.so
!addons/gamelift/bin/*.dll
!addons/gamelift/bin/*.dylib

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# CMake
cmake-build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# BUT keep the script Makefiles
!gamelift-gdextension/Makefile
!gamelift-gdextension/*/Makefile

~*.dll
