# Edgegap-targeted game-server image. Compared to the legacy
# GameLift Dockerfile this drops:
#   - GameLift Server SDK builder stage (Edgegap doesn't need it)
#   - webrtc-native v1.0.9 patch stage (Edgegap port-forwards
#     declared container ports directly, so no portRangeBegin /
#     portRangeEnd / enableIceUdpMux patches needed)
#   - entrypoint.sh Route 53 logic (Edgegap assigns hostnames)
#
# nginx is here for WebRTC signaling TLS termination — the
# entrypoint writes TLS_FULLCHAIN / TLS_PRIVKEY env vars to
# /game/tls/ and starts nginx, which fronts 4434/TCP and
# proxies plain WebSocket to Godot's signaling on 4433/TCP.
# Browser wss:// gets terminated; native ws:// passes through.
#
# Container ports declared:
#   - 4433/UDP (ENet + WebRTC DataChannels)
#   - 4434/TCP (WebRTC signaling via nginx)
#
# The Godot Linux server binary + pck are built outside via:
#   godot --headless --export-release "Linux Server" \
#     build/linux/hopnbop_server.x86_64
# and copied into the image.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    jq \
    libfontconfig1 \
    libxcursor1 \
    libxinerama1 \
    libxrandr2 \
    libxi6 \
    libgl1 \
    libssl3 \
    libstdc++6 \
    libnginx-mod-stream \
    nginx \
    openssl \
    && rm -rf /var/lib/apt/lists/*

# nginx config for WebRTC signaling TLS termination.
COPY infra/game-server/nginx.conf /etc/nginx/nginx.conf

# Standalone Godot server binary + sibling pck.
COPY build/linux/hopnbop_server.x86_64 /game/hopnbop_server.x86_64
COPY build/linux/hopnbop_server.pck /game/hopnbop_server.pck
RUN chmod +x /game/hopnbop_server.x86_64

# GDExtension manifests + .so binaries must live on disk
# (Godot can't load them from inside the pck). Only webrtc
# remains after the gamelift addon removal.
COPY addons/webrtc /game/addons/webrtc

WORKDIR /game

EXPOSE 4433/udp
EXPOSE 4434/tcp

# Edgegap injects $ARBITRARIUM_PUBLIC_IP, $ARBITRARIUM_PORT_4433_UDP_EXTERNAL,
# etc. as env vars. Server reads these via project config to advertise
# the right hostname/port back to clients.
ENV PLATFORM=edgegap
ENV TRANSPORT_PORT=4433

# Thin wrapper that registers with Nakama, then exec's the
# server binary.
COPY infra/game-server/entrypoint.sh /game/entrypoint.sh
RUN chmod +x /game/entrypoint.sh

ENTRYPOINT ["/game/entrypoint.sh"]
