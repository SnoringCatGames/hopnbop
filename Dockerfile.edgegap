# Edgegap-targeted game-server image.
#
# Compared to the legacy GameLift Dockerfile this drops:
#   - GameLift Server SDK builder stage (Edgegap doesn't need it)
#   - entrypoint.sh Route 53 logic (no per-deploy DNS in the
#     current arch — see "WebRTC signaling" below)
#
# But it KEEPS the webrtc-native patch stage that the original
# AWS-migration commit erroneously dropped (the comment claimed
# Edgegap port-forwards declared ports directly, but in practice
# the unpatched GDExtension binds ICE to an ephemeral port, the
# STUN sends fail with ENETUNREACH, and ICE never completes).
# See NOTES_FOR_BLOG_POSTS.md "ICE port nightmare" for the
# original symptom + fix.
#
# WebRTC signaling: this image runs Godot's plain WebSocket
# signaling server on container 4434/TCP — no in-container
# nginx, no per-deploy TLS, no per-deploy DNS. TLS terminates
# upstream at the Caddy-managed signaling.snoringcat.games on
# the Hetzner platform host; the stateless signaling-proxy
# there validates a signed HMAC token in the URL path and
# bridges plain WebSocket frames to (this deploy's IP,
# 4434/TCP). The Nakama runtime hook builds the
# wss://signaling.snoringcat.games/connect/<token> URL at
# match_ready time. See third_party/snoringcat-platform/
# infra/remote/signaling-proxy/main.go for the proxy.
#
# Container ports declared:
#   - 4433/UDP (ENet + WebRTC DataChannels)
#   - 4434/TCP (plain WebSocket signaling — TLS terminates
#              upstream at signaling.snoringcat.games)
#
# The Godot Linux server binary + pck are built outside via:
#   godot --headless --export-release "Linux Server" \
#     build/linux/hopnbop_server.x86_64
# and copied into the image.

# -----------------------------------------------------------------
# webrtc-native patch stage. Builds a v1.0.9 GDExtension that
# parses portRangeBegin / portRangeEnd / enableIceUdpMux from
# the initialize() config. Upstream ignores those keys, but the
# underlying libdatachannel supports them. Without this patch
# the ICE agent binds to ephemeral UDP ports that Edgegap
# doesn't forward, and STUN sends fail with ENETUNREACH. See
# infra/game-server/patch-webrtc-portrange.py for the actual
# 6-line C++ insertion.
# -----------------------------------------------------------------
FROM ubuntu:24.04 AS webrtc-builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    git \
    libssl-dev \
    pkg-config \
    python3 \
    python3-pip \
    && pip3 install --break-system-packages scons \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --recursive --branch 1.0.9-stable --depth 1 \
    https://github.com/godotengine/webrtc-native.git \
    /webrtc

WORKDIR /webrtc

COPY infra/game-server/patch-webrtc-portrange.py /tmp/
RUN python3 /tmp/patch-webrtc-portrange.py

RUN scons platform=linux target=template_release arch=x86_64 -j$(nproc)

# Resolve the built .so to a known location for the runtime stage.
RUN cp $(find /webrtc/bin -name "libwebrtc_native.linux.template_release.x86_64.so" -type f | head -1) \
       /webrtc/libwebrtc_native.linux.template_release.x86_64.so

# -----------------------------------------------------------------
# Runtime stage.
# -----------------------------------------------------------------
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    jq \
    libfontconfig1 \
    libxcursor1 \
    libxinerama1 \
    libxrandr2 \
    libxi6 \
    libgl1 \
    libssl3 \
    libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

# Standalone Godot server binary + sibling pck.
COPY build/linux/hopnbop_server.x86_64 /game/hopnbop_server.x86_64
COPY build/linux/hopnbop_server.pck /game/hopnbop_server.pck
RUN chmod +x /game/hopnbop_server.x86_64

# GDExtension manifests + .so binaries must live on disk
# (Godot can't load them from inside the pck). Only webrtc
# remains after the gamelift addon removal.
COPY addons/webrtc /game/addons/webrtc

# Overwrite the stock Linux .so with our patched build. The
# stock binary in addons/webrtc/lib/ is what the editor uses;
# the runtime stage replaces it with the port-range / mux-mode
# variant.
COPY --from=webrtc-builder \
     /webrtc/libwebrtc_native.linux.template_release.x86_64.so \
     /game/addons/webrtc/lib/libwebrtc_native.linux.template_release.x86_64.so

WORKDIR /game

EXPOSE 4433/udp
EXPOSE 4434/tcp

# Edgegap injects $ARBITRIUM_PUBLIC_IP,
# $ARBITRIUM_PORT_GAME_EXTERNAL, $ARBITRIUM_REQUEST_ID, etc. as
# env vars. Server reads these via project config to advertise
# the right hostname/port back to clients.
ENV PLATFORM=edgegap
ENV TRANSPORT_PORT=4433

# Thin wrapper that registers with Nakama, then exec's the
# server binary.
COPY infra/game-server/entrypoint.sh /game/entrypoint.sh
RUN chmod +x /game/entrypoint.sh

ENTRYPOINT ["/game/entrypoint.sh"]
