{
	"version": "2.0.0",
	"tasks": [
		// =====================================================================
		// Run Tasks
		// =====================================================================
		{
			"label": "Godot: Run Server (Preview Mode)",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"--",
				"--server",
				"--preview"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"detail": "Run game server in local preview mode"
		},
		{
			"label": "Godot: Run 3 Instances (Multi-Client Test)",
			"type": "process",
			"command": "godot",
			"args": [
				"--debug-collisions",
				"--remote-debug",
				"127.0.0.1:6007"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"detail": "Launch Godot editor for multi-instance testing (configure Debug > Customize Run Instances)"
		},
		// =====================================================================
		// Test Tasks
		// =====================================================================
		{
			"label": "Tests: Run All Tests",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"-s",
				"--path",
				".",
				"addons/gut/gut_cmdln.gd",
				"-gexit"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"group": "test",
			"detail": "Run all GUT tests (unit + integration)"
		},
		{
			"label": "Tests: Run Unit Tests",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"-s",
				"--path",
				".",
				"addons/gut/gut_cmdln.gd",
				"-gdir=res://test/unit",
				"-gexit"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"group": "test",
			"detail": "Run unit tests only"
		},
		{
			"label": "Tests: Run Integration Tests",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"-s",
				"--path",
				".",
				"addons/gut/gut_cmdln.gd",
				"-gdir=res://test/integration",
				"-gexit"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"group": "test",
			"detail": "Run integration tests only"
		},
		{
			"label": "Tests: Run Specific Test File",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"-s",
				"--path",
				".",
				"addons/gut/gut_cmdln.gd",
				"-gtest=${input:testFile}",
				"-gexit"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"group": "test",
			"detail": "Run a specific test file (prompts for path)"
		},
		{
			"label": "Tests: Run with JUnit XML Output",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"-s",
				"--path",
				".",
				"addons/gut/gut_cmdln.gd",
				"-gexit",
				"-gjunit_xml_file=test_results.xml"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"group": "test",
			"detail": "Run all tests and export JUnit XML results"
		},
		// =====================================================================
		// Development Tasks
		// =====================================================================
		{
			"label": "Dev: Format GDScript",
			"type": "shell",
			"command": "godot",
			"args": [
				"--headless",
				"--script",
				"addons/gdscript_formatter/format_project.gd",
				"--quit"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"detail": "Format all GDScript files using gdscript_formatter addon"
		},
		{
			"label": "Dev: Open Godot Editor",
			"type": "process",
			"command": "godot",
			"args": [
				"-e"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "never"
			},
			"detail": "Open Godot editor"
		},
		{
			"label": "Dev: Check for Pre-existing Errors",
			"type": "process",
			"command": "godot",
			"args": [
				"--headless",
				"--check-only",
				"--quit"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			},
			"detail": "Check for GDScript parse errors without running"
		}
	],
	// =========================================================================
	// Input Prompts
	// =========================================================================
	"inputs": [
		{
			"id": "testFile",
			"type": "promptString",
			"description": "Test file path (e.g., res://test/unit/networking/test_rollback_buffer.gd)",
			"default": "res://test/unit/"
		},
		{
			"id": "commitMessage",
			"type": "promptString",
			"description": "Commit message",
			"default": "Update"
		}
	]
}
